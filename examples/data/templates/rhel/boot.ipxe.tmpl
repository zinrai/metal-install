#!ipxe
# Boot script for RHEL-family installers (AlmaLinux, RHEL, Rocky).
# Rendered per-node by the render command.

dhcp

kernel {{ .Env.InstallServer.HTTPBase }}/{{ .OS.BootImage.Kernel }} \
  initrd=initrd.img \
  inst.repo={{ .OS.BootImage.Repo }} \
  inst.ks={{ .Env.InstallServer.HTTPBase }}/configs/{{ .Spec.NodeID }}/kickstart.ks \
  inst.text \
  rd.driver.blacklist=usb_storage \
  biosdevname=0 \
  {{ range .Machine.KernelParams }}{{ . }} {{ end }} \
  ---

initrd {{ .Env.InstallServer.HTTPBase }}/{{ .OS.BootImage.Initrd }}

boot
