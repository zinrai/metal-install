#!ipxe
# Boot script for Debian Installer.
# Rendered per-node by the render command.

dhcp

kernel http://192.0.2.1/images/debian/13/install.amd/linux \
  auto=true \
  priority=critical \
  url=http://192.0.2.1/configs/02-00-00-00-00-00/preseed.cfg \
  interface=auto \
  netcfg/dhcp_timeout=60 \
  console=tty0 console=ttyS0,115200  \
  ---

initrd http://192.0.2.1/images/debian/13/install.amd/initrd.gz

boot
